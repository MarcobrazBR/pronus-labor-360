generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum UserType {
  PRONUS_ADMIN
  PRONUS_HEALTH_PROFESSIONAL
  CLIENT_HR
  CLIENT_EMPLOYEE
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum LegalReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  RETIRED
}

enum Nr01RiskType {
  PHYSICAL
  CHEMICAL
  BIOLOGICAL
  ERGONOMIC
  ACCIDENT
}

enum Nr01ActionStatus {
  PLANNED
  IN_PROGRESS
  OVERDUE
  COMPLETED
  CANCELED
}

enum PsychosocialQuestionnaireStatus {
  IN_PROGRESS
  FINALIZED
  ABANDONED
}

model User {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  email     String?      @unique
  cpf       String?      @unique
  phone     String?
  userType  UserType     @map("user_type")
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

model OrganizationGroup {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  legalName String?      @map("legal_name")
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  companies Company[]

  @@map("organization_groups")
}

model Company {
  id                    String                             @id @default(uuid()) @db.Uuid
  organizationGroupId   String                             @map("organization_group_id") @db.Uuid
  tradeName             String                             @map("trade_name")
  legalName             String                             @map("legal_name")
  cnpj                  String                             @unique
  cnaeMain              String?                            @map("cnae_main")
  regulatoryCnaeId      String?                            @map("regulatory_cnae_id") @db.Uuid
  riskGrade             Int?                               @map("risk_grade")
  status                RecordStatus                       @default(ACTIVE)
  createdAt             DateTime                           @default(now()) @map("created_at")
  updatedAt             DateTime                           @updatedAt @map("updated_at")
  organizationGroup     OrganizationGroup                  @relation(fields: [organizationGroupId], references: [id])
  units                 CompanyUnit[]
  departments           Department[]
  jobPositions          JobPosition[]
  employees             Employee[]
  auditEvents           AuditEvent[]
  notifications         OperationalNotification[]
  regulatoryCnae        RegulatoryCnae?                    @relation(fields: [regulatoryCnaeId], references: [id])
  nr01Risks             Nr01RiskInventory[]
  nr01ActionPlans       Nr01ActionPlan[]
  nr01Evidences         Nr01Evidence[]
  psychosocialCampaigns PsychosocialCampaign[]
  psychosocialSessions  PsychosocialQuestionnaireSession[]
  psychosocialReports   PsychosocialTechnicalReport[]
  lgpdConsents          LgpdConsentRecord[]
  sensitiveAccessTrail  SensitiveAccessTrail[]
  esocialSstQueue       ESocialSstEventQueue[]

  @@map("companies")
}

model CompanyUnit {
  id          String              @id @default(uuid()) @db.Uuid
  companyId   String              @map("company_id") @db.Uuid
  name        String
  code        String?
  status      RecordStatus        @default(ACTIVE)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  company     Company             @relation(fields: [companyId], references: [id])
  departments Department[]
  employees   Employee[]
  nr01Risks   Nr01RiskInventory[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@map("company_units")
}

model Department {
  id            String              @id @default(uuid()) @db.Uuid
  companyId     String              @map("company_id") @db.Uuid
  companyUnitId String?             @map("company_unit_id") @db.Uuid
  name          String
  code          String?
  status        RecordStatus        @default(ACTIVE)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  company       Company             @relation(fields: [companyId], references: [id])
  companyUnit   CompanyUnit?        @relation(fields: [companyUnitId], references: [id])
  jobPositions  JobPosition[]
  employees     Employee[]
  nr01Risks     Nr01RiskInventory[]

  @@unique([companyId, companyUnitId, name])
  @@unique([companyId, code])
  @@map("departments")
}

model JobPosition {
  id           String              @id @default(uuid()) @db.Uuid
  companyId    String              @map("company_id") @db.Uuid
  departmentId String?             @map("department_id") @db.Uuid
  title        String
  eSocialCode  String?             @map("esocial_code")
  cboCode      String?             @map("cbo_code")
  description  String?
  status       RecordStatus        @default(ACTIVE)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  company      Company             @relation(fields: [companyId], references: [id])
  department   Department?         @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  nr01Risks    Nr01RiskInventory[]

  @@unique([companyId, departmentId, title])
  @@unique([companyId, eSocialCode])
  @@index([companyId, cboCode])
  @@map("job_positions")
}

model Employee {
  id                   String                             @id @default(uuid()) @db.Uuid
  userId               String?                            @map("user_id") @db.Uuid
  companyId            String                             @map("company_id") @db.Uuid
  companyUnitId        String?                            @map("company_unit_id") @db.Uuid
  departmentId         String?                            @map("department_id") @db.Uuid
  jobPositionId        String?                            @map("job_position_id") @db.Uuid
  cpf                  String
  fullName             String                             @map("full_name")
  socialName           String?                            @map("social_name")
  birthDate            DateTime?                          @map("birth_date") @db.Date
  sex                  String?
  email                String?
  phone                String?
  whatsapp             String?
  employeeRegistration String?                            @map("employee_registration")
  workerCategoryCode   String?                            @map("worker_category_code")
  cboCode              String?                            @map("cbo_code")
  admissionDate        DateTime?                          @map("admission_date") @db.Date
  employmentStatus     String                             @default("active") @map("employment_status")
  hasMedicalPlan       Boolean                            @default(false) @map("has_medical_plan")
  hasDentalPlan        Boolean                            @default(false) @map("has_dental_plan")
  hasLifeInsurance     Boolean                            @default(false) @map("has_life_insurance")
  registrationStatus   String                             @default("pending_validation") @map("registration_status")
  createdAt            DateTime                           @default(now()) @map("created_at")
  updatedAt            DateTime                           @updatedAt @map("updated_at")
  company              Company                            @relation(fields: [companyId], references: [id])
  companyUnit          CompanyUnit?                       @relation(fields: [companyUnitId], references: [id])
  department           Department?                        @relation(fields: [departmentId], references: [id])
  jobPosition          JobPosition?                       @relation(fields: [jobPositionId], references: [id])
  auditEvents          AuditEvent[]
  notifications        OperationalNotification[]
  nr01Risks            Nr01RiskInventory[]
  psychosocialSessions PsychosocialQuestionnaireSession[]
  lgpdConsents         LgpdConsentRecord[]
  sensitiveAccessTrail SensitiveAccessTrail[]
  esocialSstQueue      ESocialSstEventQueue[]

  @@unique([companyId, cpf])
  @@index([companyId, departmentId, jobPositionId])
  @@map("employees")
}

model AuditEvent {
  id          String    @id @default(uuid()) @db.Uuid
  scope       String
  action      String
  companyId   String?   @map("company_id") @db.Uuid
  employeeId  String?   @map("employee_id") @db.Uuid
  movementId  String?   @map("movement_id") @db.Uuid
  actorUserId String?   @map("actor_user_id") @db.Uuid
  actorName   String    @map("actor_name")
  actorRole   String    @map("actor_role")
  summary     String
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  company     Company?  @relation(fields: [companyId], references: [id])
  employee    Employee? @relation(fields: [employeeId], references: [id])

  @@index([companyId, createdAt])
  @@index([employeeId, createdAt])
  @@map("audit_events")
}

model OperationalNotification {
  id         String    @id @default(uuid()) @db.Uuid
  status     String
  severity   String
  type       String
  companyId  String    @map("company_id") @db.Uuid
  employeeId String?   @map("employee_id") @db.Uuid
  movementId String?   @map("movement_id") @db.Uuid
  title      String
  message    String
  createdAt  DateTime  @default(now()) @map("created_at")
  dueAt      DateTime  @map("due_at")
  resolvedAt DateTime? @map("resolved_at")
  company    Company   @relation(fields: [companyId], references: [id])
  employee   Employee? @relation(fields: [employeeId], references: [id])

  @@index([companyId, status, dueAt])
  @@map("operational_notifications")
}

model RegulatoryRiskDegree {
  id                String            @id @default(uuid()) @db.Uuid
  degree            Int               @unique
  description       String
  analysisDepth     String            @map("analysis_depth")
  requiredRiskTypes Json              @map("required_risk_types")
  automaticRules    Json              @map("automatic_rules")
  reviewFrequency   String?           @map("review_frequency")
  sourceUrl         String?           @map("source_url")
  sourceVersion     String?           @map("source_version")
  effectiveFrom     DateTime?         @map("effective_from") @db.Date
  effectiveTo       DateTime?         @map("effective_to") @db.Date
  legalReviewStatus LegalReviewStatus @default(PENDING_REVIEW) @map("legal_review_status")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  cnaes             RegulatoryCnae[]

  @@map("regulatory_risk_degrees")
}

model RegulatoryCnae {
  id                     String                @id @default(uuid()) @db.Uuid
  code                   String                @unique
  description            String
  riskDegreeId           String?               @map("risk_degree_id") @db.Uuid
  riskDegree             Int?                  @map("risk_degree")
  activityClassification String?               @map("activity_classification")
  obligations            Json
  nr04Rules              Json?                 @map("nr04_rules")
  cipaRules              Json?                 @map("cipa_rules")
  sesmtRules             Json?                 @map("sesmt_rules")
  technicalNotes         String?               @map("technical_notes")
  sourceUrl              String?               @map("source_url")
  sourceVersion          String?               @map("source_version")
  effectiveFrom          DateTime?             @map("effective_from") @db.Date
  effectiveTo            DateTime?             @map("effective_to") @db.Date
  legalReviewStatus      LegalReviewStatus     @default(PENDING_REVIEW) @map("legal_review_status")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  reviewedBy             String?               @map("reviewed_by")
  reviewedAt             DateTime?             @map("reviewed_at")
  riskDegreeReference    RegulatoryRiskDegree? @relation(fields: [riskDegreeId], references: [id])
  companies              Company[]

  @@index([riskDegree])
  @@index([legalReviewStatus])
  @@map("regulatory_cnaes")
}

model Nr01RiskInventory {
  id              String           @id @default(uuid()) @db.Uuid
  companyId       String           @map("company_id") @db.Uuid
  companyUnitId   String?          @map("company_unit_id") @db.Uuid
  departmentId    String?          @map("department_id") @db.Uuid
  jobPositionId   String?          @map("job_position_id") @db.Uuid
  employeeId      String?          @map("employee_id") @db.Uuid
  gheCode         String?          @map("ghe_code")
  riskType        Nr01RiskType     @map("risk_type")
  agent           String
  source          String?          @map("source")
  exposureTime    String?          @map("exposure_time")
  controlMeasures String?          @map("control_measures")
  probability     Int?
  severity        Int?
  riskLevel       RiskLevel        @map("risk_level")
  legalBasis      String?          @map("legal_basis")
  assessmentDate  DateTime?        @map("assessment_date") @db.Date
  responsibleName String?          @map("responsible_name")
  status          RecordStatus     @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  company         Company          @relation(fields: [companyId], references: [id])
  companyUnit     CompanyUnit?     @relation(fields: [companyUnitId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  jobPosition     JobPosition?     @relation(fields: [jobPositionId], references: [id])
  employee        Employee?        @relation(fields: [employeeId], references: [id])
  actionPlans     Nr01ActionPlan[]
  evidences       Nr01Evidence[]

  @@index([companyId, riskType, riskLevel])
  @@index([departmentId, jobPositionId])
  @@map("nr01_risk_inventory")
}

model Nr01ActionPlan {
  id              String            @id @default(uuid()) @db.Uuid
  companyId       String            @map("company_id") @db.Uuid
  riskId          String            @map("risk_id") @db.Uuid
  title           String
  description     String?
  responsibleName String?           @map("responsible_name")
  dueDate         DateTime?         @map("due_date") @db.Date
  status          Nr01ActionStatus  @default(PLANNED)
  completedAt     DateTime?         @map("completed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  company         Company           @relation(fields: [companyId], references: [id])
  risk            Nr01RiskInventory @relation(fields: [riskId], references: [id])
  evidences       Nr01Evidence[]

  @@index([companyId, status, dueDate])
  @@map("nr01_action_plans")
}

model Nr01Evidence {
  id           String             @id @default(uuid()) @db.Uuid
  companyId    String             @map("company_id") @db.Uuid
  riskId       String?            @map("risk_id") @db.Uuid
  actionPlanId String?            @map("action_plan_id") @db.Uuid
  title        String
  description  String?
  fileUrl      String             @map("file_url")
  fileType     String?            @map("file_type")
  uploadedBy   String?            @map("uploaded_by")
  uploadedAt   DateTime           @default(now()) @map("uploaded_at")
  company      Company            @relation(fields: [companyId], references: [id])
  risk         Nr01RiskInventory? @relation(fields: [riskId], references: [id])
  actionPlan   Nr01ActionPlan?    @relation(fields: [actionPlanId], references: [id])

  @@index([companyId, uploadedAt])
  @@map("nr01_evidences")
}

model PsychosocialCampaign {
  id                 String                             @id @default(uuid()) @db.Uuid
  companyId          String                             @map("company_id") @db.Uuid
  name               String
  startDate          DateTime                           @map("start_date") @db.Date
  endDate            DateTime                           @map("end_date") @db.Date
  targetParticipants Int                                @map("target_participants")
  responseCount      Int                                @default(0) @map("response_count")
  responseRate       Int                                @default(0) @map("response_rate")
  status             String                             @default("draft")
  createdAt          DateTime                           @default(now()) @map("created_at")
  updatedAt          DateTime                           @updatedAt @map("updated_at")
  company            Company                            @relation(fields: [companyId], references: [id])
  sessions           PsychosocialQuestionnaireSession[]
  technicalReports   PsychosocialTechnicalReport[]

  @@index([companyId, status, endDate])
  @@map("psychosocial_campaigns")
}

model PsychosocialQuestion {
  id            String   @id @default(uuid()) @db.Uuid
  questionKey   String   @unique @map("question_key")
  order         Int
  axis          String?
  factor        String
  prompt        String
  reverseScored Boolean  @default(false) @map("reverse_scored")
  options       Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([active, order])
  @@map("psychosocial_questions")
}

model PsychosocialQuestionnaireSession {
  id              String                            @id @default(uuid()) @db.Uuid
  campaignId      String                            @map("campaign_id") @db.Uuid
  companyId       String                            @map("company_id") @db.Uuid
  employeeId      String                            @map("employee_id") @db.Uuid
  sectorName      String                            @map("sector_name")
  status          PsychosocialQuestionnaireStatus   @default(IN_PROGRESS)
  answeredCount   Int                               @default(0) @map("answered_count")
  totalQuestions  Int                               @default(0) @map("total_questions")
  progressPercent Int                               @default(0) @map("progress_percent")
  averageScore    Decimal?                          @map("average_score") @db.Decimal(5, 2)
  riskPercent     Decimal?                          @map("risk_percent") @db.Decimal(5, 2)
  riskLevel       RiskLevel?                        @map("risk_level")
  startedAt       DateTime                          @default(now()) @map("started_at")
  updatedAt       DateTime                          @updatedAt @map("updated_at")
  finalizedAt     DateTime?                         @map("finalized_at")
  campaign        PsychosocialCampaign              @relation(fields: [campaignId], references: [id])
  company         Company                           @relation(fields: [companyId], references: [id])
  employee        Employee                          @relation(fields: [employeeId], references: [id])
  answers         PsychosocialQuestionnaireAnswer[]

  @@unique([campaignId, employeeId])
  @@index([companyId, status, updatedAt])
  @@index([employeeId, updatedAt])
  @@map("psychosocial_questionnaire_sessions")
}

model PsychosocialQuestionnaireAnswer {
  id          String                           @id @default(uuid()) @db.Uuid
  sessionId   String                           @map("session_id") @db.Uuid
  questionKey String                           @map("question_key")
  axis        String?
  score       Int
  riskScore   Int?                             @map("risk_score")
  answeredAt  DateTime                         @default(now()) @map("answered_at")
  session     PsychosocialQuestionnaireSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, questionKey])
  @@index([axis])
  @@map("psychosocial_questionnaire_answers")
}

model PsychosocialTechnicalReport {
  id                        String               @id @default(uuid()) @db.Uuid
  campaignId                String               @map("campaign_id") @db.Uuid
  companyId                 String               @map("company_id") @db.Uuid
  minimumAnonymousGroupSize Int                  @map("minimum_anonymous_group_size")
  totalResponses            Int                  @map("total_responses")
  visibleGroups             Int                  @map("visible_groups")
  aggregatedGroups          Int                  @map("aggregated_groups")
  overallRiskPercent        Decimal              @map("overall_risk_percent") @db.Decimal(5, 2)
  overallRiskLevel          RiskLevel            @map("overall_risk_level")
  priorityAxisLabel         String               @map("priority_axis_label")
  executiveSummary          String               @map("executive_summary")
  interventionPlan          Json                 @map("intervention_plan")
  generatedAt               DateTime             @default(now()) @map("generated_at")
  campaign                  PsychosocialCampaign @relation(fields: [campaignId], references: [id])
  company                   Company              @relation(fields: [companyId], references: [id])

  @@index([companyId, generatedAt])
  @@map("psychosocial_technical_reports")
}

model LgpdConsentRecord {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String?   @map("company_id") @db.Uuid
  employeeId     String?   @map("employee_id") @db.Uuid
  subjectType    String    @map("subject_type")
  subjectId      String    @map("subject_id")
  subjectName    String    @map("subject_name")
  purpose        String
  legalBasis     String    @map("legal_basis")
  status         String
  version        String
  channel        String
  evidenceHash   String?   @map("evidence_hash")
  grantedAt      DateTime? @map("granted_at")
  revokedAt      DateTime? @map("revoked_at")
  retentionUntil DateTime? @map("retention_until") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  company        Company?  @relation(fields: [companyId], references: [id])
  employee       Employee? @relation(fields: [employeeId], references: [id])

  @@index([companyId, purpose, status])
  @@index([employeeId, purpose])
  @@map("lgpd_consent_records")
}

model LgpdRetentionPolicy {
  id                    String   @id @default(uuid()) @db.Uuid
  dataDomain            String   @map("data_domain")
  legalBasis            String   @map("legal_basis")
  retentionPeriodMonths Int      @map("retention_period_months")
  deletionAction        String   @map("deletion_action")
  reviewFrequency       String   @map("review_frequency")
  ownerRole             String   @map("owner_role")
  active                Boolean  @default(true)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([active, dataDomain])
  @@map("lgpd_retention_policies")
}

model AttachmentSecurityPolicy {
  id                 String   @id @default(uuid()) @db.Uuid
  bucketName         String   @unique @map("bucket_name")
  dataClass          String   @map("data_class")
  allowedMimeTypes   Json     @map("allowed_mime_types")
  maxSizeMb          Int      @map("max_size_mb")
  encryptionRequired Boolean  @default(true) @map("encryption_required")
  signedUrlMinutes   Int      @map("signed_url_minutes")
  retentionPolicyId  String?  @map("retention_policy_id") @db.Uuid
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([dataClass, active])
  @@map("attachment_security_policies")
}

model SensitiveAccessTrail {
  id            String    @id @default(uuid()) @db.Uuid
  companyId     String?   @map("company_id") @db.Uuid
  employeeId    String?   @map("employee_id") @db.Uuid
  actorUserId   String?   @map("actor_user_id") @db.Uuid
  actorName     String    @map("actor_name")
  actorRole     String    @map("actor_role")
  dataDomain    String    @map("data_domain")
  action        String
  decision      String
  purpose       String
  reason        String?
  ipHash        String?   @map("ip_hash")
  userAgentHash String?   @map("user_agent_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  company       Company?  @relation(fields: [companyId], references: [id])
  employee      Employee? @relation(fields: [employeeId], references: [id])

  @@index([companyId, dataDomain, createdAt])
  @@index([employeeId, dataDomain, createdAt])
  @@map("sensitive_access_trail")
}

model ESocialSstEventQueue {
  id                      String    @id @default(uuid()) @db.Uuid
  companyId               String    @map("company_id") @db.Uuid
  employeeId              String?   @map("employee_id") @db.Uuid
  eventType               String    @map("event_type")
  sourceModule            String    @map("source_module")
  sourceReferenceId       String?   @map("source_reference_id")
  status                  String
  schemaVersion           String    @map("schema_version")
  payloadSummary          Json      @map("payload_summary")
  validationMessages      Json      @map("validation_messages")
  futureSubmissionEnabled Boolean   @default(false) @map("future_submission_enabled")
  generatedAt             DateTime  @default(now()) @map("generated_at")
  dueAt                   DateTime? @map("due_at") @db.Date
  lockedAt                DateTime? @map("locked_at")
  company                 Company   @relation(fields: [companyId], references: [id])
  employee                Employee? @relation(fields: [employeeId], references: [id])

  @@index([companyId, eventType, status])
  @@index([employeeId, eventType])
  @@map("esocial_sst_event_queue")
}
