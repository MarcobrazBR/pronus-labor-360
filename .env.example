NODE_ENV=development

# Frontends AWS/Next.js - variaveis publicas
# Estas chaves podem ir para os quatro portais na AWS.
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=true

# API NestJS - variaveis privadas do backend
API_PORT=3333
API_PUBLIC_URL=http://localhost:3333
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Supabase privado do backend
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_DOCUMENTS=documents
SUPABASE_STORAGE_BUCKET_CLINICAL=clinical-records

# PostgreSQL Supabase/Prisma
# DATABASE_URL deve usar a connection pooler URL do Supabase em homologacao/producao.
# DIRECT_URL deve usar a conexao direta para migrations Prisma.
DATABASE_URL=
DIRECT_URL=

# IA e rotinas clinicas futuras
OPENAI_API_KEY=
